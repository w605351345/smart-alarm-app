/* pages/index/index.wxss */

.container {
  padding: 0;
  background-color: var(--background-color);
}

/* 头部信息 */
.header {
  background: linear-gradient(135deg, #4A90D9, #3A7BC8);
  padding: 48rpx 32rpx 64rpx;
  border-radius: 0 0 48rpx 48rpx;
}

.date-section {
  margin-bottom: 32rpx;
}

.date {
  display: block;
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 8rpx;
}

.greeting {
  display: block;
  font-size: 48rpx;
  font-weight: 600;
  color: #FFFFFF;
}

.weather-section {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background-color: rgba(255, 255, 255, 0.2);
  padding: 24rpx 32rpx;
  border-radius: 24rpx;
}

.weather-info {
  display: flex;
  align-items: center;
}

.weather-icon {
  font-size: 48rpx;
  margin-right: 16rpx;
}

.weather-temp {
  font-size: 40rpx;
  font-weight: 600;
  color: #FFFFFF;
}

.weather-desc {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
}

/* 章节标题 */
.section-title {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 32rpx 16rpx;
}

.title {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.count {
  font-size: 26rpx;
  color: var(--text-hint);
}

/* 闹钟列表 */
.alarm-list {
  padding: 0 32rpx;
}

.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 80rpx;
  color: var(--text-hint);
}

/* 闹钟卡片 */
.alarm-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.alarm-main {
  flex: 1;
}

.alarm-time {
  font-size: 56rpx;
  font-weight: 600;
  color: var(--text-primary);
  line-height: 1.2;
  margin-bottom: 8rpx;
}

.alarm-info {
  display: flex;
  flex-direction: column;
}

.alarm-name {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: 4rpx;
}

.alarm-repeat {
  font-size: 24rpx;
  color: var(--text-hint);
}

/* 闹钟操作 */
.alarm-actions {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 16rpx;
}

.delete-btn {
  padding: 12rpx 24rpx;
  background-color: #FFF0F0;
  border-radius: 12rpx;
}

.delete-btn text {
  font-size: 24rpx;
  color: #F5222D;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 48rpx;
  text-align: center;
}

.empty-image {
  width: 280rpx;
  height: 280rpx;
  margin-bottom: 32rpx;
  opacity: 0.6;
}

.empty-text {
  font-size: 32rpx;
  color: var(--text-secondary);
  margin-bottom: 16rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: var(--text-hint);
}

/* 添加按钮 */
.add-button {
  position: fixed;
  right: 48rpx;
  bottom: calc(48rpx + env(safe-area-inset-bottom));
  width: 112rpx;
  height: 112rpx;
  background: linear-gradient(135deg, #4A90D9, #3A7BC8);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(74, 144, 217, 0.4);
  z-index: 100;
}

.add-button:active {
  transform: scale(0.95);
}

.add-icon {
  font-size: 64rpx;
  color: #FFFFFF;
  font-weight: 300;
  line-height: 1;
}

/* 停止事件冒泡 */
stopPropagation {
  pointer-events: none;
}
