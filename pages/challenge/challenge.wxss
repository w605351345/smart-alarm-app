/* pages/challenge/challenge.wxss - 解密挑战页面样式 */

.container {
  padding: 0 32rpx;
  padding-bottom: 120rpx;
  background-color: #F5F5F5;
  min-height: 100vh;
}

/* 头部 */
.header {
  padding: 48rpx 0 32rpx;
  text-align: center;
}

.title {
  font-size: 44rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 12rpx;
}

.subtitle {
  font-size: 28rpx;
  color: #999999;
}

/* 章节 */
.section {
  margin-bottom: 40rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 24rpx;
  padding-left: 8rpx;
}

/* 难度网格 */
.difficulty-grid {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.difficulty-card {
  background-color: #FFFFFF;
  border-radius: 20rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
  transition: all 0.3s;
  border: 2rpx solid transparent;
}

.difficulty-card.active {
  border-color: #4A90D9;
  background-color: rgba(74, 144, 217, 0.05);
}

.difficulty-icon {
  font-size: 36rpx;
  margin-bottom: 12rpx;
}

.difficulty-label {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 8rpx;
}

.difficulty-desc {
  font-size: 26rpx;
  color: #999999;
  margin-bottom: 16rpx;
}

.difficulty-info {
  display: flex;
  gap: 24rpx;
}

.info-item {
  font-size: 24rpx;
  color: #666666;
}

/* 题目类型网格 */
.type-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.type-card {
  background-color: #FFFFFF;
  border-radius: 20rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
  text-align: center;
  transition: all 0.3s;
  border: 2rpx solid transparent;
}

.type-card.active {
  border-color: #4A90D9;
  background-color: rgba(74, 144, 217, 0.05);
}

.type-icon {
  font-size: 56rpx;
  margin-bottom: 12rpx;
}

.type-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 8rpx;
}

.type-desc {
  font-size: 22rpx;
  color: #999999;
}

/* 开关行 */
.switch-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background-color: #FFFFFF;
  border-radius: 20rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.switch-label {
  flex: 1;
}

.label-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 8rpx;
}

.label-desc {
  font-size: 24rpx;
  color: #999999;
}

/* 保存按钮 */
.save-section {
  margin-top: 48rpx;
}

.save-btn {
  background: linear-gradient(135deg, #4A90D9, #3A7BC8);
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 600;
  padding: 32rpx;
  border-radius: 16rpx;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(74, 144, 217, 0.4);
}

.save-btn[disabled] {
  background: #CCCCCC;
  box-shadow: none;
}

/* 答题页面样式 */
.challenge-container {
  padding: 48rpx 32rpx;
  background-color: #F5F5F5;
  min-height: 100vh;
}

.challenge-header {
  text-align: center;
  margin-bottom: 48rpx;
}

.challenge-title {
  font-size: 40rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 16rpx;
}

.challenge-timer {
  display: inline-flex;
  align-items: center;
  background-color: #FFF0F0;
  padding: 12rpx 24rpx;
  border-radius: 24rpx;
  color: #F5222D;
  font-size: 28rpx;
  font-weight: 600;
}

.question-card {
  background-color: #FFFFFF;
  border-radius: 24rpx;
  padding: 48rpx 32rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 4rpx 20px rgba(0, 0, 0, 0.08);
}

.question-text {
  font-size: 36rpx;
  color: #333333;
  line-height: 1.6;
  text-align: center;
  margin-bottom: 32rpx;
}

.answer-input {
  width: 100%;
  height: 100rpx;
  background-color: #F5F5F5;
  border-radius: 16rpx;
  padding: 0 32rpx;
  font-size: 40rpx;
  text-align: center;
  border: 2rpx solid #EEEEEE;
}

.answer-input:focus {
  border-color: #4A90D9;
  background-color: #FFFFFF;
}

.submit-btn {
  background: linear-gradient(135deg, #4A90D9, #3A7BC8);
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 600;
  padding: 32rpx;
  border-radius: 16rpx;
  border: none;
  margin-top: 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(74, 144, 217, 0.4);
}

.attempts-info {
  text-align: center;
  margin-top: 24rpx;
  font-size: 26rpx;
  color: #999999;
}

/* 结果提示 */
.result-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.result-content {
  background-color: #FFFFFF;
  border-radius: 24rpx;
  padding: 64rpx 48rpx;
  text-align: center;
  width: 80%;
  max-width: 600rpx;
}

.result-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.result-title {
  font-size: 40rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 16rpx;
}

.result-message {
  font-size: 28rpx;
  color: #999999;
  margin-bottom: 32rpx;
}

.result-btn {
  background: linear-gradient(135deg, #4A90D9, #3A7BC8);
  color: #FFFFFF;
  font-size: 30rpx;
  font-weight: 600;
  padding: 24rpx 64rpx;
  border-radius: 16rpx;
  border: none;
}
