/* pages/challenge/answer.wxss - 答题页面样式 */

.challenge-container {
  padding: 48rpx 32rpx;
  padding-bottom: 120rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  min-height: 100vh;
}

.challenge-header {
  text-align: center;
  margin-bottom: 48rpx;
}

.challenge-title {
  font-size: 40rpx;
  font-weight: 600;
  color: #FFFFFF;
  margin-bottom: 16rpx;
}

.challenge-timer {
  display: inline-flex;
  align-items: center;
  background-color: rgba(255, 255, 255, 0.2);
  padding: 12rpx 24rpx;
  border-radius: 24rpx;
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 600;
  backdrop-filter: blur(10px);
}

.question-card {
  background-color: #FFFFFF;
  border-radius: 24rpx;
  padding: 48rpx 32rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.15);
}

.question-text {
  font-size: 36rpx;
  color: #333333;
  line-height: 1.6;
  text-align: center;
  margin-bottom: 48rpx;
  font-weight: 500;
}

.answer-input {
  width: 100%;
  height: 100rpx;
  background-color: #F5F5F5;
  border-radius: 16rpx;
  padding: 0 32rpx;
  font-size: 40rpx;
  text-align: center;
  border: 3rpx solid #EEEEEE;
  transition: all 0.3s;
}

.answer-input:focus {
  border-color: #4A90D9;
  background-color: #FFFFFF;
}

.attempts-info {
  text-align: center;
  margin-top: 32rpx;
  font-size: 26rpx;
  color: #999999;
}

.submit-btn {
  background: linear-gradient(135deg, #4A90D9, #3A7BC8);
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 600;
  padding: 32rpx;
  border-radius: 16rpx;
  border: none;
  margin-top: 48rpx;
  box-shadow: 0 8rpx 24rpx rgba(74, 144, 217, 0.4);
}

.submit-btn:active {
  transform: scale(0.98);
}

.hint-text {
  text-align: center;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 32rpx;
}

/* 结果弹窗 */
.result-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  animation: fadeIn 0.3s ease;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.result-content {
  background-color: #FFFFFF;
  border-radius: 24rpx;
  padding: 64rpx 48rpx;
  text-align: center;
  width: 80%;
  max-width: 600rpx;
  animation: slideUp 0.3s ease;
}

@keyframes slideUp {
  from { 
    opacity: 0;
    transform: translateY(50rpx);
  }
  to { 
    opacity: 1;
    transform: translateY(0);
  }
}

.result-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.result-title {
  font-size: 40rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 16rpx;
}

.result-message {
  font-size: 28rpx;
  color: #999999;
  margin-bottom: 48rpx;
  line-height: 1.5;
}

.result-btn {
  background: linear-gradient(135deg, #4A90D9, #3A7BC8);
  color: #FFFFFF;
  font-size: 30rpx;
  font-weight: 600;
  padding: 24rpx 64rpx;
  border-radius: 16rpx;
  border: none;
  box-shadow: 0 4rpx 16rpx rgba(74, 144, 217, 0.3);
}

.result-btn:active {
  transform: scale(0.98);
}
